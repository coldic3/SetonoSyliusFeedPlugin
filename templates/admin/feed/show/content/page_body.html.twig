{# @var \Setono\SyliusFeedPlugin\Model\FeedInterface resource #}
{% set feed = hookable_metadata.context.resource %}

<div class="container-xl mt-4">
    {% if workflow_has_marked_place(feed, constant('Setono\\SyliusFeedPlugin\\Workflow\\FeedGraph::STATE_READY')) or workflow_has_marked_place(feed, constant('Setono\\SyliusFeedPlugin\\Workflow\\FeedGraph::STATE_PROCESSING')) %}
        <div class="card mb-3">
            <div class="card-body p-0">
                <table class="table table-bordered mb-0">
                    <thead>
                        <tr>
                            <th>{{ 'sylius.ui.channel'|trans }}</th>
                            <th>{{ 'sylius.ui.locale'|trans }}</th>
                            <th>{{ 'setono_sylius_feed.ui.link'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for channel in feed.channels %}
                            {% for locale in channel.locales %}
                                <tr>
                                    <td>{{ channel.name }}</td>
                                    <td>{{ locale.name }}</td>
                                    <td>
                                        <div class="input-group">
                                            <input id="link-{{ loop.parent.loop.index }}-{{ loop.index }}"
                                                   type="text"
                                                   class="form-control"
                                                   value="{{ setono_sylius_feed_generate_feed_url(feed, channel, locale) }}"
                                                   readonly>
                                            <button class="btn btn-outline-secondary copy-link-btn"
                                                    type="button"
                                                    data-link-id="link-{{ loop.parent.loop.index }}-{{ loop.index }}"
                                                    title="{{ 'setono_sylius_feed.ui.click_to_copy'|trans }}">
                                                {{ ux_icon('tabler:copy') }}
                                            </button>
                                        </div>
                                        <small class="text-success copy-feedback d-none"
                                               id="link-copied-{{ loop.parent.loop.index }}-{{ loop.index }}">
                                            {{ 'setono_sylius_feed.ui.link_copied'|trans }}
                                        </small>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% else %}
        <div class="alert alert-info mb-3">
            <h4 class="alert-heading">{{ 'setono_sylius_feed.ui.unprocessed_feed_header'|trans }}</h4>
            <p class="mb-0">{{ 'setono_sylius_feed.ui.unprocessed_feed_body'|trans }}</p>
        </div>
    {% endif %}

    {% if feed.violations|length > 0 %}
        <h2 class="h4 mb-3">{{ 'setono_sylius_feed.ui.violation_summary'|trans }}</h2>
        <p>{{ 'setono_sylius_feed.ui.view_all_violations'|trans({'%path%': path('setono_sylius_feed_admin_feed_violations_index', {'id': feed.id})})|raw }}</p>
        {{ render(controller('setono_sylius_feed.controller.action.admin.severity_count', {'feed': feed.id})) }}
    {% endif %}
</div>

<script>
    document.querySelectorAll('.copy-link-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            const linkId = this.dataset.linkId;
            const input = document.getElementById(linkId);
            const feedbackId = 'link-copied-' + linkId.replace(/^link-/, '');
            const feedback = document.getElementById(feedbackId);

            navigator.clipboard.writeText(input.value).then(function () {
                if (feedback) {
                    feedback.classList.remove('d-none');
                    setTimeout(function () { feedback.classList.add('d-none'); }, 3000);
                }
            });
        });
    });
</script>
